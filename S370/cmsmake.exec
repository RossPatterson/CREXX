   Say 'RXBVME' || Debug? '-V'
   'RXBVME' || Debug? '-V'
   'COPY RXBVME' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A RXBVME' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE RXBVME' || Debug? 'MODULE A'

   /* C Library Interpreter -  to be linked to make a standalone CREXX exe - Threaded Version */
   ParmFn = 'CREXX' || Debug?
   'GCC RXVMMAIN C' SourceDisk '( CMS PARM' ParmFn 'CSECT'
   'GCC RXVMINTP C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXVMLOAD C' SourceDisk '( CMS PARM' ParmFn
   'GCC INTERRUP C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXSPAWN  C' SourceDisk '( CMS PARM' ParmFn
   'GCC EXITFUNC C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXPAFUNC C' SourceDisk '( CMS PARM' ParmFn
