   'GENMOD RXVML' || Debug? '( FROM RXVMMAI@'
   Say 'RXVML' || Debug? '-V'
   'RXVML' || Debug? '-V'
   'COPY RXVML' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A RXVML' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE RXVML' || Debug? 'MODULE A'

   /* C Library Interpreter -  to be linked to make a standalone CREXX exe - Bytecode Version */
   ParmFn = 'C_ISB' || Debug?
   'GCC RXVMMAIN C' SourceDisk '( CMS PARM' ParmFn 'CSECT'
   'GCC RXVMINTP C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXVMLOAD C' SourceDisk '( CMS PARM' ParmFn
   'GCC INTERRUP C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXSPAWN  C' SourceDisk '( CMS PARM' ParmFn
   'GCC EXITFUNC C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXPAFUNC C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXVMRUN  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXVMLIB  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXVML    C' SourceDisk '( CMS PARM' ParmFn

   'GLOBAL TXTLIB MC_DECIMAL_MANUAL GCCLIB'
   'LOAD RXVMMAIN RXVMINTP RXVMLOAD INTERRUP RXSPAWN EXITFUNC RXPAFUNC' ,
      'RXVMRUN LIBRARY ( CLEAR RESET @@MAIN'
   'GENMOD RXBVML' || Debug? '( FROM RXVMMAI@'
   Say 'RXBVML' || Debug? '-V'
   'RXBVML' || Debug? '-V'
   'COPY RXBVML' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A RXBVML' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE RXBVML' || Debug? 'MODULE A'
end

