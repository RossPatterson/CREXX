/* This exec builds CREXX */
/*
Signal on Error
*/
'SPOOL CONS START TO * PURGE'
Trace C
Arg SourceDisk BinaryDisk

If SourceDisk = '' then SourceDisk = 'D'
If BinaryDisk = '' then BinaryDisk = 'E'

/* Build DEBUG versions */
Call Build 'D', SourceDisk, BinaryDisk
/*
/* Build non-DEBUG versions */
Call Build '',SourceDisk, BinaryDisk
*/

Call Test SourceDisk
Exit 0

Error:
Say 'Error' RC 'in line' SigL':' SourceLine(SigL)
Exit RC

Build: Procedure
   Arg Debug?, SourceDisk, BinaryDisk

   /* The order of these builds matters, because of included TEXT files. */
   Call BuildCMS          Debug?, SourceDisk, BinaryDisk
   Call BuildPlatform     Debug?, SourceDisk, BinaryDisk
   Call BuildAvlTree      Debug?, SourceDisk, BinaryDisk
   Call BuildAssembler    Debug?, SourceDisk, BinaryDisk
   Call BuildCPacker      Debug?, SourceDisk, BinaryDisk
   Call BuildCompiler     Debug?, SourceDisk, BinaryDisk
return
   Call BuildLinker       Debug?, SourceDisk, BinaryDisk
   Call BuildDisassembler Debug?, SourceDisk, BinaryDisk
   /* Call BuildDebugger     Debug?, SourceDisk, BinaryDisk */
   Call BuildInterpreter  Debug?, SourceDisk, BinaryDisk
   Call BuildRxPA         Debug?, SourceDisk, BinaryDisk
   /* Call BuildLib          Debug?, SourceDisk, BinaryDisk */
   /* Call BuildDemos        Debug?, SourceDisk, BinaryDisk */
   /* Call BuildTests        Debug?, SourceDisk, BinaryDisk */
   Call BuildBin          Debug?, SourceDisk, BinaryDisk
   Call BuildCRexxDriver  Debug?, SourceDisk, BinaryDisk

   /* CLEANUP */
   'LISTFILE * TEXT A ( EXEC'
   'EXPLOIT COPY &FN &FT A = =' BinaryDisk '(OLDDATE REPLACE'
   'ERASE * TEXT A'
   'ERASE * MODULE A'
   'ERASE LOAD MAP A'

Return

BuildCMS: Procedure
   Arg Debug?, SourceDisk, BinaryDisk
   ParmFn = 'CREXX' || Debug?

   /* S370/... */
   'GCC CMSUTIL  C' SourceDisk '( CMS PARM' ParmFn

Return

BuildPlatform: Procedure
   Arg Debug?, SourceDisk, BinaryDisk
   ParmFn = 'CREXX' || Debug?

   /* platform/CMakeLists.txt */
   'GCC PLATFORM C' SourceDisk '( CMS PARM' ParmFn
   'GCC SPLTPAR C' SourceDisk '( CMS PARM' ParmFn 'CSECT'

   'GLOBAL TXTLIB GCCLIB'
   'LOAD SPLTPAR ( CLEAR RESET @@MAIN'
   'GENMOD SPLTPAR' || Debug? '( FROM SPLTPAR@'
   'COPY SPLTPAR' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A SPLTPAR' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'

Return


BuildAvlTree: Procedure
   Arg Debug?, SourceDisk, BinaryDisk
   ParmFn = 'CREXX' || Debug?

   /* AVLTREE/CMakeLists.txt */
   'GCC AVLTREE  C' SourceDisk '( CMS PARM' ParmFn

Return


BuildAssembler: Procedure
   Arg Debug?, SourceDisk, BinaryDisk
   ParmFn = 'CREXX' || Debug?

   /* assembler/CMakeLists.txt */
   'GCC RXASASSM C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXASDSL  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXASEROR C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXASGRMR C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXASLIB  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXASMAIN C' SourceDisk '( CMS PARM' ParmFn 'CSECT'
   'GCC RXASOPT  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXASSCAN C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXASTOKE C' SourceDisk '( CMS PARM' ParmFn

   'GLOBAL TXTLIB GCCLIB'
   'LOAD RXASMAIN RXASEROR RXASASSM RXASLIB RXASOPT RXASGRMR RXASSCAN' ,
      'RXASTOKE CMSUTIL AVLTREE PLATFORM ( CLEAR RESET @@MAIN'
   'GENMOD RXAS' || Debug? '( FROM RXASMAI@'
   Say 'RXAS' || Debug? '-V'
   'RXAS' || Debug? '-V'
   'COPY RXAS' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A RXAS' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE RXAS' || Debug? 'MODULE A'

Return


BuildCPacker: Procedure
   Arg Debug?, SourceDisk, BinaryDisk
   ParmFn = 'CREXX' || Debug?

   /* cpacker/CMakeLists.txt */
   'GCC RXCPACK C' SourceDisk '( CMS PARM' ParmFn 'CSECT'

   'GLOBAL TXTLIB GCCLIB'
   'LOAD RXCPACK CMSUTIL PLATFORM ( CLEAR RESET @@MAIN'
   'GENMOD RXCPACK' || Debug? '(FROM RXCPACK@'
   Say 'RXCPACK' || Debug? '-V'
   'RXCPACK' || Debug? '-V'
   'COPY RXCPACK' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A RXCPACK' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE RXCPACK' || Debug? 'MODULE A'

Return


BuildCompiler: Procedure
   Arg Debug?, SourceDisk, BinaryDisk
   ParmFn = 'CREXX' || Debug?

'SPLTPAR' || Debug? 'rxcpbgmr.c.' || SourceDisk 'rxcpbg'
   'GCC REXBSCAN C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPBG03 C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPBG04 C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPBG05 C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPBG06 C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPBG07 C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPBG09 C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPBG10 C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPBPAR C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPFUNC C' SourceDisk '( CMS PARM' ParmFn
'SVCTRACE ON'
   'GCC RXCPMAIN C' SourceDisk '( CMS PARM' ParmFn 'CSECT'
'SVCTRACE OFF'
   'GCC RXCPOPAR C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPOPGR C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPOSCN C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPSYMB C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCUTIL   C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCACORE  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCAPRT   C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCAREWRT C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCASVAL  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCAWALK  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCDIAGFB C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPDSL  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPEMIT C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCECORE  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCEEXPR  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCEFLOW  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCEMETA  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCEPROC  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCEREG   C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCEXIT   C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCFIXUP  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCHICTL  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCINLINE C' SourceDisk '( CMS PARM' ParmFn
   'GCC RXCPOPT  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCSRCTR  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCVCHECK C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCVORCH  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCVPLGIN C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCVSYM   C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCVTRANS C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCVTYPE  C' SourceDisk '( CMS PARM' ParmFn
   'GCC RCINSTR  C' SourceDisk '( CMS PARM' ParmFn

   'GLOBAL TXTLIB GCCLIB'
   'LOAD RXCPMAIN RCACORE RCAPRT RCAREWRT RCASVAL RCAWALK RCUTIL' ,
      'RCDIAGFB RXCPDSL RCHICTL RXCPOSCN RXCPOPGR RXCPOPAR REXBSCAN' ,
      'RXCPBG03 RXCPBG04 RXCPBG05 RXCPBG06 RXCPBG07 RXCPBG09 RXCPBG10' ,
      'RXCPBPAR RCSRCTR RCVCHECK RCVORCH RCVPLGIN RCVSYM RCVTRANS RCVTYPE' ,
      'RXCPSYMB RCFIXUP RCINLINE RCECORE RCEEXPR RCEFLOW RCEMETA' ,
      'RCEPROC RCEREG RXCPOPT RXCPFUNC RCEXIT CMSUTIL ( CLEAR RESET RXCPMAI@'
   'GENMOD RXC' || Debug? '( FROM RXCPMAI@'

   Say 'RXC' || Debug? '-V'
   'RXC' || Debug? '-V'
   'COPY RXC' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A RXC' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE RXC' || Debug? 'MODULE A'

Return


BuildLinker: Procedure
   Arg Debug?, SourceDisk, BinaryDisk
   ParmFn = 'CREXX' || Debug?

   'GCC RXLKMAIN C' SourceDisk '( CMS PARM' ParmFn 'CSECT'

   'GLOBAL TXTLIB GCCLIB'
   'LOAD RXLKMAIN CMSUTIL PLATFORM ( CLEAR RESET @@MAIN'
   'GENMOD RXLINK' || Debug? '( FROM RXLKMAI@'
   Say 'RXLINK' || Debug? '-H'
   'RXLINK' || Debug? '-H'
   'COPY RXLINK' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A RXLINK' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE RXLINK' || Debug? 'MODULE A'

Return


BuildDisassembler: Procedure
   Arg Debug?, SourceDisk, BinaryDisk
   ParmFn = 'CREXX' || Debug?

   'GCC RXDAMAIN C' SourceDisk '( CMS PARM' ParmFn 'CSECT'
   'GCC RXDADISM C' SourceDisk '( CMS PARM' ParmFn

   'GLOBAL TXTLIB GCCLIB'
   'LOAD RXDAMAIN RXDADISM CMSUTIL PLATFORM ( CLEAR RESET @@MAIN'
   'GENMOD RXDAS' || Debug? '( FROM RXDAMAI@'
   Say 'RXDAS' || Debug? '-V'
   'RXDAS' || Debug? '-V'
   'COPY RXDAS' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A RXDAS' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE RXDAS' || Debug? 'MODULE A'

Return


