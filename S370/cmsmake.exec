   'COPY LOAD MAP A RXBVM' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE RXBVM' || Debug? 'MODULE A'

   /* Interpreter linked to CREXX Stdlib - Threaded Version */
