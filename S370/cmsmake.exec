BuildBin: Procedure
   Arg Debug?, SourceDisk, BinaryDisk

   'RXC -i "./bin; ./lib/plugins/system" -o ./crexx CREXX'
   'RXAS CREXX'
   'RXLINK -s -o CREXX_LINKED crexx ./bin/library'
   'RXCPACK -o CREXX CREXX_LINKED'

Return


BuildCRexxDriver: Procedure
   Arg Debug?, SourceDisk, BinaryDisk
   ParmFn = 'CREXX' || Debug?

   'RXC -i "bin;lib/plugins/system" -o crexx CREXX'
   'RXAS CREXX'
   'RXLINK -s -o crexx_linked crexx bin/library'
   'RXCPACK -o crexx crexx_linked'
   'GCC CREXX C A ( CMS PARM' ParmFn 'CSECT'

   'GLOBAL TXTLIB GCCLIB'
   'LOAD CREXX'
   'GENMOD CREXX' || Debug? '( FROM CREXX@@@'
   Say 'CREXX' || Debug? '-V'
   'CREXX' || Debug? '-V'
   'COPY CREXX' || Debug? 'MODULE A = =' BinaryDisk '( OLDDATE REPLACE'
   'COPY LOAD MAP A CREXX' || Debug? '=' BinaryDisk '( OLDDATE REPLACE'
   'ERASE CREXX' || Debug? 'MODULE A'

Return


Test: Procedure
   Arg SourceDisk

   Say 'RX COMPILE'
   'RXC -V'

   Say 'RX ASSEMBLE'
   'RXAS -V'
   'RXAS -I'
   'RXAS -A'

   /* Panic - toDo */
   Say 'RX DISASSEMBLE'
   'RXDAS -V'

   /* Out of memory - toDo */
   Say 'RX RUN'
   'RXBVM -V'

   /* Tests */
   /* Panic - toDo */
   'RXAS -L' SourceDisk 'ASCOMMON'

   /* Out of memory - toDo */
   'RXBVM -L' SourceDisk 'ASCOMMON'

   /* Panic - toDo */
   'RXAS -L' SourceDisk 'ASEBCDIC'

   /* Out of memory - toDo */
   'RXBVM -L' SourceDisk 'ASEBCDIC'

   /* Panic - toDo */
   'RXC -L' SourceDisk 'BASIC'

   /* Panic - toDo */
   'RXAS -L' SourceDisk 'BASIC'

   /* Out of memory - toDo */
   'RXBVM -L' SourceDisk 'BASIC'

Return
